{
  "name": "browser-change-verifier",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "mcp": "tsx src/mcp/server.ts",
    "mcp:vision": "tsx src/mcp/vision-server.ts",
    "mcp:agent": "tsx src/mcp/agent-server.ts",
    "prepare:plugin": "npm run typecheck && npm run build && npm test",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.183",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chrome-remote-interface": "^0.34.0",
    "tsx": "^4.22.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.34.0",
    "@types/node": "^20.14.10",
    "devtools-protocol": "^0.0.1648812",
    "rolldown": "^1.1.2",
    "typescript": "^5.5.3"
  }
}
